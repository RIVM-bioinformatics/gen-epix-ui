{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: start",
      "type": "shell",
      "command": "pnpm run start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "a^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+https?://(?:localhost|127\\.0\\.0\\.1):5010/"
        }
      }
    }
  ]
}