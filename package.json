{
  "name": "@gen-epix/monorepo",
  "version": "0.0.1",
  "license": "EUPL-1.2",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "start": "concurrently \"pnpm --filter @gen-epix/demo-client run oidc-server\" \"pnpm --filter @gen-epix/demo-client run start\"",
    "clean": "lerna clean && rm -fr node_modules"
  },
  "pnpm": {
    "overrides": {
      "@openapitools/openapi-generator-cli>axios": "1.13.6",
      "typescript": "5.9.2"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@openapitools/openapi-generator-cli",
      "@swc/core",
      "nx",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "lerna": "9.0.7"
  }
}