{
  "name": "@gen-epix/monorepo",
  "version": "0.0.1",
  "license": "EUPL-1.2",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "start": "concurrently \"pnpm --filter @gen-epix/demo-client run oidc-server\" \"pnpm --filter @gen-epix/demo-client run start\"",
    "clean": "lerna clean && rm -fr node_modules",
    "generate-api": "pnpm --filter @gen-epix/ui run generate-api",
    "validate": "lerna run validate"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "lerna": "9.0.7"
  }
}