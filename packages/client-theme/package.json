{
  "name": "@gen-epix/client-theme",
  "version": "0.2.0",
  "license": "EUPL-1.2",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RIVM-bioinformatics/gen-epix-ui.git"
  },
  "type": "module",
  "types": "./src/@types/mui.d.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "validate": "pnpm run check-types",
    "check-types": "tsc --noemit",
