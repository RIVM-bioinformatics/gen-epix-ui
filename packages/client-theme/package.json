{
  "name": "@gen-epix/client-theme",
  "version": "0.0.1",
  "license": "EUPL-1.2",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./src/@types/mui.d.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "validate": "pnpm run check-types",
    "check-types": "tsc --noemit",
