    "lint-fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix",
    "build-publish": "pnpm publish --access=public"
  },
  "dependencies": {
    "@mui/material": "9.0.0"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "0.2.0",
    "@types/node": "25.6.0",
    "eslint": "10.2.0",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}