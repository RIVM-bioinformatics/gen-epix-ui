{
  "name": "@gen-epix/demo-client",
  "version": "0.0.1",
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "start": "vite",
    "test-run": "vitest run --passWithNoTests",
    "test-missing-translations": "translation-util ./ --dry-run --fail-on-missing --fail-on-stale",
    "add-missing-translations": "translation-util ./",
    "validate": "pnpm run lint && pnpm run check-types && pnpm run test-missing-translations",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix",
    "check-types": "tsc --noemit",
    "oidc-server": "nodemon --watch ../../oidc-mock-server.config.json --exec oidc-mock-server"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@gen-epix/api-casedb": "workspace:*",
    "@gen-epix/client-theme": "workspace:*",
    "@gen-epix/demo-theme": "workspace:*",
    "@gen-epix/ui": "workspace:*",
    "@mui/icons-material": "9.0.0",
    "@mui/material": "9.0.0",
    "@mui/styled-engine": "9.0.0",
    "@mui/system": "9.0.0",
    "@mui/utils": "9.0.0",
    "@mui/x-date-pickers": "9.0.0",
    "date-fns": "4.1.0",
    "i18next": "26.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "17.0.2",
    "react-router-dom": "7.14.0"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "0.2.0",
    "@gen-epix/generate-license-manifest": "0.1.1",
    "@gen-epix/oidc-mock-server": "0.1.1",
    "@gen-epix/tools-lib": "0.1.1",
    "@gen-epix/translation-util": "0.1.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.0",
    "husky": "^9.1.7",
    "nodemon": "3.1.14",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-static-copy": "4.0.1",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.4"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}