{
  "name": "@gen-epix/demo-client",
  "version": "0.0.1",
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "start": "vite",
    "test-run": "vitest run --passWithNoTests",
    "test-missing-translations": "translation-util ./ --dry-run --fail-on-missing --fail-on-stale",
    "add-missing-translations": "translation-util ./",
    "validate": "pnpm run lint && pnpm run check-types && pnpm run test-missing-translations",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix",
    "check-types": "tsc --noemit",
    "oidc-server": "nodemon --watch ../../oidc-mock-server.config.json --exec oidc-mock-server"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@gen-epix/client-theme": "workspace:*",
    "@gen-epix/demo-theme": "workspace:*",
    "@gen-epix/ui": "workspace:*",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/styled-engine": "7.3.9",
    "@mui/system": "7.3.9",
    "@mui/utils": "7.3.9",
    "@mui/x-date-pickers": "8.27.2",
    "date-fns": "4.1.0",
    "i18next": "26.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "17.0.2",
    "react-router-dom": "7.14.0"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "0.0.30",
    "@gen-epix/generate-license-manifest": "0.0.7",
    "@gen-epix/oidc-mock-server": "0.0.9",
    "@gen-epix/tools-lib": "0.0.6",
    "@gen-epix/translation-util": "0.0.5",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "nodemon": "3.1.14",
    "typescript": "5.9.2",
    "vite": "8.0.5",
    "vite-plugin-static-copy": "4.0.1",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.3"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}