{
  "name": "@gen-epix/ui-omopdb",
  "version": "1.25.0",
  "license": "EUPL-1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RIVM-bioinformatics/gen-epix-ui.git"
  },
  "author": "RIVM-bioinformatics <ids-bioinformatics@rivm.nl>",
  "homepage": "https://github.com/RIVM-bioinformatics/gen-epix",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/ui.d.ts"
      }
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/@types/ui.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "build-publish": "pnpm build && pnpm publish --access=public",
    "test-missing-translations": "translation-util ./ --dry-run --fail-on-missing --fail-on-stale",
    "add-missing-translations": "translation-util ./",
    "_FIXME_validate": "pnpm run lint && pnpm run check-types && pnpm run test-run && pnpm run test-missing-translations",
    "test": "vitest --coverage",
    "test-run": "vitest run --passWithNoTests --coverage",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix",
    "check-types": "tsc --noemit"
  },
  "peerDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@gen-epix/ui": "workspace:*",
    "@gen-epix/api-commondb": "workspace:*",
    "@gen-epix/api-casedb": "workspace:*",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/styled-engine": "^9.0.0",
    "@mui/system": "^9.0.0",
    "@mui/utils": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.2",
    "i18next": "^26.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.3",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "0.2.3",
    "@gen-epix/translation-util": "0.1.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.0",
    "jsdom": "29.0.2",
    "playwright": "1.59.1",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-lib-inject-css": "2.2.2",
    "vite-plugin-static-copy": "4.0.1",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.4"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}