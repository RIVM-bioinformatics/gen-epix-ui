{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strictNullChecks": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "../ui-casedb/src/utils/AbacUtil",
    "../ui-casedb/src/utils/EpiUploadUtil",
    "../ui-casedb/src/utils/EpiTreeUtil",
    "../ui-casedb/src/utils/EpiMapUtil",
    "../ui-casedb/src/utils/EpiLineListUtil",
    "../ui-casedb/src/utils/EpiFilterUtil",
    "../ui-casedb/src/utils/EpiCurveUtil",
    "../ui-casedb/src/utils/EffectiveRightsUtil",
    "../ui-casedb/src/utils/CaseSelectionUtil",
    "../ui-casedb/src/utils/CaseSetUtil",
    "../ui-casedb/src/utils/CaseTypeUtil",
    "../ui-casedb/src/utils/CaseUtil",
    "../ui-casedb/src/utils/DashboardUtil",
    "../ui-casedb/src/utils/DataUtil",
    "../ui-casedb/src/utils/DataSetUtil",
    "../ui-casedb/src/stores/epiDashboardStore",
    "../ui-casedb/src/stores/epiUploadStore",
  ]
}