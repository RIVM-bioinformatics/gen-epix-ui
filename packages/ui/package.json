  "publishConfig": {
    "access": "public",
    "files": [
      "dist"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/ui.d.ts"
      }
    }
