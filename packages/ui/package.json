  "type": "module",
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "scripts": {
    "build": "vite build",
    "build-publish": "pnpm build && pnpm publish --access=public",
    "test-missing-translations": "translation-util ./ --dry-run --fail-on-missing --fail-on-stale",
    "add-missing-translations": "translation-util ./",
    "validate": "pnpm run lint && pnpm run check-types && pnpm run test-run && pnpm run test-missing-translations",
    "test": "vitest --coverage",
    "test-run": "vitest run --passWithNoTests --coverage",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix",
    "check-types": "tsc --noemit",
    "generate-api": "generate-api ./src/api",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
