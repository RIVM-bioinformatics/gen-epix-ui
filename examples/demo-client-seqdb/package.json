{
  "name": "@gen-epix/demo-client-seqdb",
  "version": "0.0.1",
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "start": "vite",
    "test-run": "vitest run --passWithNoTests",
    "test-missing-translations": "translation-util ./ --dry-run --fail-on-missing --fail-on-stale",
    "add-missing-translations": "translation-util ./",
    "validate": "pnpm run lint && pnpm run check-types && pnpm run test-missing-translations",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix",
    "check-types": "tsc --noemit",
    "oidc-server": "nodemon --watch ../../oidc-mock-server.config.json --exec oidc-mock-server"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@gen-epix/api-seqdb": "workspace:^",
    "@gen-epix/ui": "workspace:^",
    "@gen-epix/ui-seqdb": "workspace:^",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/styled-engine": "9.0.0",
    "@mui/system": "9.0.1",
    "@mui/utils": "9.0.1",
    "@mui/x-date-pickers": "9.2.0",
    "axios": "1.16.1",
    "date-fns": "4.1.0",
    "i18next": "26.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.7",
    "react-router-dom": "7.15.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@gen-epix/eslint-config": "0.3.2",
    "@gen-epix/generate-license-manifest": "0.2.0",
    "@gen-epix/oidc-mock-server": "0.1.1",
    "@gen-epix/tools-lib": "0.1.1",
    "@gen-epix/translation-util": "0.1.1",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "nodemon": "3.1.14",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-plugin-static-copy": "4.1.0",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.6"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}